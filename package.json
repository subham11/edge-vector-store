{
  "name": "@sukshm/edge-vector-store",
  "version": "0.1.0",
  "description": "Unified on-device vector store for React Native — USearch ANN + SQLite metadata + .evs pack format",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "cpp",
    "third_party",
    "android",
    "ios",
    "edge-vector-store.podspec",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "del-cli lib android/build ios/build"
  },
  "keywords": [
    "react-native",
    "vector-database",
    "edge-ai",
    "usearch",
    "ann",
    "hnsw",
    "embeddings",
    "on-device"
  ],
  "license": "MIT",
  "devDependencies": {
    "react-native": ">=0.73.0",
    "react-native-builder-bob": "^0.30.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.73.0"
  },
  "codegenConfig": {
    "name": "EdgeVectorStoreSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.edgevectorstore"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "project": "tsconfig.json" }]
    ]
  }
}
